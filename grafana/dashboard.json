{
  "annotations": {
    "list": []
  },
  "description": "AI-Powered Log Anomaly Detection \u2014 Real-time monitoring of anomalies detected by the Isolation Forest model",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "\ud83d\udea8 Anomaly Count Over Time",
      "description": "Number of anomalies detected per time bucket. Spikes indicate potential incidents.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "LogAnomaly",
          "metricName": "AnomalyCount",
          "statistics": [
            "Sum"
          ],
          "period": "300"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "title": "\ud83d\udcca Detection Summary",
      "description": "Quick stats: total logs processed vs anomalies detected",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "LogAnomaly",
          "metricName": "AnomalyCount",
          "statistics": [
            "Sum"
          ],
          "period": "3600"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "title": "\u23f1\ufe0f Response Time Distribution",
      "description": "P50, P95, P99 response times. High P99 indicates tail latency issues.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "LogAnomaly",
          "metricName": "ResponseTime",
          "statistics": [
            "p50",
            "p95",
            "p99"
          ],
          "period": "300"
        }
      ]
    },
    {
      "title": "\ud83d\udccb Recent Anomaly Details",
      "description": "Table of recent anomalies with service, status code, response time, and anomaly score",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "logGroupNames": [
            "/aws/lambda/log-anomaly-detector-dev"
          ],
          "queryMode": "Logs",
          "expression": "fields @timestamp, log_entry.service as service, features.response_time_ms as latency_ms, features.status_code as status_code, anomaly_score | filter type = 'ANOMALY_DETAIL' | sort @timestamp desc | limit 20",
          "id": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "anomaly_score"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": -0.3
                    },
                    {
                      "color": "green",
                      "value": 0
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "\ud83d\udd25 Anomalies by Service",
      "description": "Which microservices are producing the most anomalies",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "logGroupNames": [
            "/aws/lambda/log-anomaly-detector-dev"
          ],
          "queryMode": "Logs",
          "expression": "fields @timestamp, log_entry.service as service | filter type = 'ANOMALY_DETAIL' | stats count() as anomalies by service",
          "id": "A"
        }
      ]
    },
    {
      "title": "\ud83d\udcc8 Error Rate Over Time",
      "description": "Percentage of 5xx errors in the log stream",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "namespace": "LogAnomaly",
          "metricName": "ErrorRate",
          "statistics": [
            "Average"
          ],
          "period": "300"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      }
    },
    {
      "title": "\ud83d\udd14 Alert History",
      "description": "Timeline of SNS alerts triggered by the anomaly detector",
      "type": "logs",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "logGroupNames": [
            "/aws/lambda/log-anomaly-detector-dev"
          ],
          "queryMode": "Logs",
          "expression": "fields @timestamp, @message | filter @message like /ANOMALY/ | sort @timestamp desc | limit 50"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "anomaly-detection",
    "logs",
    "ai",
    "monitoring"
  ],
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "current": {
          "text": "dev",
          "value": "dev"
        },
        "options": [
          {
            "text": "dev",
            "value": "dev"
          },
          {
            "text": "staging",
            "value": "staging"
          },
          {
            "text": "prod",
            "value": "prod"
          }
        ]
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "\ud83d\udd0d Log Anomaly Detection Dashboard",
  "uid": "log-anomaly-detection",
  "version": 1
}